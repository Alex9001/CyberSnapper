{
  "presets": [
    {
      "name": "Desktop",
      "width": 1920,
      "height": 1080
    },
    {
      "name": "Tablet",
      "width": 768,
      "height": 1024
    },
    {
      "name": "Mobile",
      "width": 375,
      "height": 812
    }
  ],
  "initialDelay": 1.5,
  "scrollDelay": 1.8,
  "finalDelay": 1.0,
  "concurrency": 1,
  "formats": ["png"],
  "webp": { "quality": 80 },
  "avif": { "quality": 50 },
  "pdf": {
    "format": "A4",
    "landscape": false,
    "margin": "0"
  },
  "hideSelectors": [],
  "waitForSelector": "",
  "blockPopups": false,
  "naming": {
    "template": "{hostname}-{preset}"
  }
}