{
  "name": "cybersnapper",
  "version": "1.0.0",
  "description": "Full-page screenshots at Desktop, Tablet, and Mobile viewports — CLI and Web UI, powered by Playwright",
  "main": "capture.js",
  "bin": {
    "cybersnapper": "./capture.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "build": "node build.js",
    "pkg": "npx @yao-pkg/pkg src/index.js --targets node22-linux-x64 --output dist/CyberSnapper"
  },
  "pkg": {
    "assets": [
      "node_modules/playwright-core/browsers.json"
    ]
  },
  "keywords": [
    "screenshot",
    "full-page",
    "playwright",
    "viewport",
    "responsive",
    "web",
    "cli",
    "automation",
    "testing",
    "capture",
    "snapshot"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "bugs": "",
  "dependencies": {
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "esbuild": "^0.25.12"
  }
}
